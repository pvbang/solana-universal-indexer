# Solana Universal Indexer Environment Variables

# Solana RPC
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_WS_URL=wss://api.mainnet-beta.solana.com
# For better performance, use Helius or Quicknode:
# SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/solana_indexer
DATABASE_POOL_SIZE=20

# Redis (for BullMQ job queue)
REDIS_URL=redis://localhost:6379

# API Server
PORT=3000
API_PREFIX=/api
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Indexer Settings
INDEXER_BATCH_SIZE=100
INDEXER_RETRY_DELAY=5000
INDEXER_MAX_RETRIES=3
INDEXER_COMMITMENT=confirmed

# Monitoring
METRICS_ENABLED=true
METRICS_PORT=9090

# Logging
LOG_LEVEL=info
LOG_FORMAT=json
