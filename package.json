{
  "name": "solana-universal-indexer",
  "version": "1.0.0",
  "description": "Universal Solana Indexer with Dynamic Schema & REST API",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:seed": "tsx src/db/seed.ts",
    "test": "vitest",
    "lint": "eslint src/",
    "format": "prettier --write src/"
  },
  "dependencies": {
    "@solana/web3.js": "^1.95.0",
    "express": "^4.18.2",
    "pg": "^8.12.0",
    "bullmq": "^5.0.0",
    "ioredis": "^5.3.2",
    "zod": "^3.22.0",
    "prom-client": "^15.1.0",
    "winston": "^3.11.0",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "dotenv": "^16.3.1",
    "swagger-ui-express": "^5.0.0",
    "bs58": "^5.0.0"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "tsx": "^4.7.0",
    "vitest": "^1.3.0",
    "@types/express": "^4.17.21",
    "@types/pg": "^8.10.9",
    "@types/cors": "^2.8.17",
    "eslint": "^8.56.0",
    "prettier": "^3.2.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
